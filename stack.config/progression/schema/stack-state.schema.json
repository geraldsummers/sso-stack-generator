{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webservices.local/schema/progression-stack-state.schema.json",
  "type": "object",
  "required": ["generatedAt", "claims"],
  "properties": {
    "generatedAt": { "type": "string" },
    "claims": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "facts": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
