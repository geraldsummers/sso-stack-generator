{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webservices.local/schema/progression-dashboard.schema.json",
  "type": "object",
  "required": ["dashboards"],
  "properties": {
    "dashboards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "stage", "density", "panels", "commands"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
          "title": { "type": "string" },
          "stage": { "type": "string" },
          "density": { "enum": ["low", "medium", "high"] },
          "foregroundWhen": { "type": "array", "items": { "type": "string" } },
          "recommendedAfter": { "type": "array", "items": { "type": "string" } },
          "emotionalTone": { "type": "array", "items": { "type": "string" } },
          "panels": {
            "type": "object",
            "properties": {
              "beginner": { "type": "array", "items": { "type": "string" } },
              "operator": { "type": "array", "items": { "type": "string" } },
              "expert": { "type": "array", "items": { "type": "string" } }
            }
          },
          "commands": { "type": "array", "items": { "type": "string" } },
          "forbiddenByDefault": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
