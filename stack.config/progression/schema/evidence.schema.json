{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webservices.local/schema/progression-evidence.schema.json",
  "type": "object",
  "required": ["id", "generatedAt", "claims", "summary"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
    "generatedAt": { "type": "string" },
    "summary": { "type": "string" },
    "claims": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
