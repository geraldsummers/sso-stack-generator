# SOGo groupware.
sogo.{$DOMAIN} {
	import access_observability
	route {
		@sogo_root path /
		redir @sogo_root /SOGo/ 302
		reverse_proxy sogo:80 {
			header_up x-webobjects-server-name sogo.{$DOMAIN}
			header_up x-webobjects-server-port 443
			header_up x-webobjects-server-protocol https
			header_up x-webobjects-server-url https://sogo.{$DOMAIN}
			header_up x-webobjects-remote-user {header.Remote-Email}
		}
	}
}

# Jellyfin media library.
jellyfin.{$DOMAIN} {
	import access_observability
	route {
		@jellyfin_native_hls_hevc {
			path /videos/*/hls1/main/*
			query VideoCodec=*hevc*
		}
		uri @jellyfin_native_hls_hevc query {
			VideoCodec h264
			RequireAvc true
			TranscodeReasons VideoCodecNotSupported,AudioChannelsNotSupported
			-hevc-level
			-hevc-videobitdepth
			-hevc-profile
		}

		@jellyfin_password_login {
			path /Users/AuthenticateByName /Users/authenticatebyname
		}
		respond @jellyfin_password_login "Jellyfin password login is disabled; use Keycloak SSO" 403
		reverse_proxy jellyfin-profile-proxy:8080 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Server {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Port {server_port}
		}
	}
}

