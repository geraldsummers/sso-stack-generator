	route {
			@mcp path /mcp
			reverse_proxy @mcp chatgpt-connector:8130
			import keycloak_auth chatgpt_connector
			reverse_proxy chatgpt-connector:8130 {
				header_up X-Trusted-Proxy-Secret {$CHATGPT_CONNECTOR_TRUSTED_PROXY_SECRET}
			}
		}
	}
