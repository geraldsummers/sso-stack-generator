# Low-risk protected route proving the Keycloak forward-auth replacement path
# without touching app-local account linkage.
keycloak-whoami.{$DOMAIN} {
	import access_observability
	route {
		import keycloak_auth keycloak-whoami
		header Content-Type text/plain
		respond "authenticated by Keycloak as {http.request.header.Remote-User}" 200
	}
}

# Onboarding landing page for users who still need Keycloak required-action completion.
onboarding.{$DOMAIN} {
	import access_observability
	route {
		request_header -Remote-User
		request_header -Remote-Groups
		request_header -Remote-Name
		request_header -Remote-Email
		request_header -X-Remote-User
		request_header -X-Remote-Groups
		request_header -X-Remote-Name
		request_header -X-Remote-Email
		request_header -X-Trusted-Proxy-Secret

		@onboarding_public path /start /api/invites/signup
		reverse_proxy @onboarding_public onboarding:8080 {
			header_up -Remote-User
			header_up -Remote-Groups
			header_up -Remote-Name
			header_up -Remote-Email
			header_up -X-Remote-User
			header_up -X-Remote-Groups
			header_up -X-Remote-Name
			header_up -X-Remote-Email
				header_up X-Trusted-Proxy-Secret {$ONBOARDING_TRUSTED_PROXY_SECRET}
		}

			handle {
				import keycloak_auth_base onboarding
				reverse_proxy onboarding:8080 {
				header_up -Remote-User
				header_up -Remote-Groups
				header_up -Remote-Name
				header_up -Remote-Email
				header_up X-Remote-User {header.Remote-User}
					header_up X-Remote-Groups {header.Remote-Groups}
					header_up X-Remote-Name {header.Remote-Name}
					header_up X-Remote-Email {header.Remote-Email}
					header_up X-Trusted-Proxy-Secret {$ONBOARDING_TRUSTED_PROXY_SECRET}
				}
			}
	}
}

