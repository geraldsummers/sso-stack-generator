# Forgejo (Git Forge) - with OIDC authentication via Keycloak
forgejo.{$DOMAIN} {
	import access_observability
	@forgejo_token_api path_regexp forgejo_token_api ^/api/v1/users/[^/]+/tokens/?$
	respond @forgejo_token_api "Forgejo password token creation is disabled" 403
	reverse_proxy forgejo:3000
}

