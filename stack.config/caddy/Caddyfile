###############################################
# Caddy config for webservices
#
# - Official Caddy image + a static Caddyfile (no docker label proxy).
# - Most apps are protected with Keycloak-backed forward_auth where labels
#   previously specified shared authentication.
#
# Env vars used inside this file (must be provided to the Caddy container):
# - DOMAIN                     (e.g. example.com)
# - API_MODELS_ALLOWLIST      (space-separated CIDRs)
# - KOPIA_PROXY_AUTHORIZATION (Basic auth header for the Caddy -> Kopia hop)
# - BOOKSTACK_INTERNAL_API_TOKEN (shared token for api.bookstack.$DOMAIN)
# - CHATGPT_CONNECTOR_TRUSTED_PROXY_SECRET (trusted-proxy secret for ChatGPT Connector)
# - ONBOARDING_TRUSTED_PROXY_SECRET (trusted-proxy secret for onboarding)
# - SEARCH_SERVICE_INTERNAL_TOKEN (shared token for Caddy -> search-service)
# - STACK_ADMIN_EMAIL          (e.g. admin@example.com)
# - VAULTWARDEN_ORG_ID         (vaultwarden org UUID for SSO policy resolution)
# - WORKSPACE_PROXY_AUTH_SECRET (trusted-proxy secret for internal auth hops)
#
# TLS Configuration:
# - Render-selected mode; local PKI is the current default.
# - ACME is supported when explicitly enabled in site config.
# - Certificates are stored in /certs (named volume caddy_certs).
###############################################
{
{{CADDY_GLOBAL_OPTIONS}}
}

# Privacy-bounded access logs for account/service usage dashboards.
# Keep request bodies, request/response headers, URL paths, query strings,
# cookies, and full client IPs out of Loki; dashboards use appended
# user/service fields instead.
(access_observability) {
	log {
		output stdout
		format filter {
			wrap json
			request>headers delete
			request>uri delete
			resp_headers delete
			request>remote_ip ip_mask 24 48
			request>client_ip ip_mask 24 48
		}
	}
}

# Snippet for Keycloak-backed OAuth2 Proxy Forward Auth.
(keycloak_auth_base) {
	route {
		@trusted_proxy_{args[0]} {
			header X-Trusted-Proxy-Secret {$WORKSPACE_PROXY_AUTH_SECRET}
			remote_ip private_ranges
		}
		handle @trusted_proxy_{args[0]} {
			request_header Remote-User {http.request.header.X-Remote-User}
			request_header Remote-Groups {http.request.header.X-Remote-Groups}
			request_header Remote-Name {http.request.header.X-Remote-Name}
			request_header Remote-Email {http.request.header.X-Remote-Email}
			request_header -X-Trusted-Proxy-Secret
			log_append auth_user {http.request.header.Remote-User}
			log_append service {args[0]}
		}

		handle {
			route {
				request_header -Remote-User
				request_header -Remote-Groups
				request_header -Remote-Name
					request_header -Remote-Email
					request_header -X-Remote-User
					request_header -X-Remote-Groups
					request_header -X-Remote-Name
					request_header -X-Remote-Email
					request_header -X-Auth-Request-User
					request_header -X-Auth-Request-Groups
					request_header -X-Auth-Request-Email
					request_header -Authorization

					forward_auth keycloak-auth-gateway:4180 {
					uri /oauth2/auth
					copy_headers X-Auth-Request-Preferred-Username>Remote-User X-Auth-Request-Groups>Remote-Groups X-Auth-Request-Email>Remote-Email
					@unauth status 401 403
					handle_response @unauth {
						redir https://keycloak-auth.{$DOMAIN}/oauth2/start?rd={scheme}://{host}{uri} temporary
					}
				}
				log_append auth_user {http.request.header.Remote-User}
				log_append service {args[0]}
			}
		}
	}
}

(keycloak_auth) {
	route {
		import keycloak_auth_base {args[0]}

		@onboarding_required_{args[0]} header Remote-Groups *onboarding_required*
		redir @onboarding_required_{args[0]} https://onboarding.{$DOMAIN}/start temporary
		@onboarding_required_legacy_{args[0]} header Remote-Groups *onboarding-required*
		redir @onboarding_required_legacy_{args[0]} https://onboarding.{$DOMAIN}/start temporary
	}
}

