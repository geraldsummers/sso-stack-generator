# Workspace provisioner UI/API
workspaces.{$DOMAIN} {
	import access_observability
	route {
		@workspace_shell_root path_regexp workspace_shell_root ^/w/([^/]+)/shell$
		handle @workspace_shell_root {
			redir /w/{re.workspace_shell_root.1}/shell/ 308
		}
		@workspace_shell path_regexp workspace_shell ^/w/([^/]+)/shell(/.*)?$
		handle @workspace_shell {
			route {
				import keycloak_auth workspaces_shell
				request_header X-Remote-User {header.Remote-User}
				request_header X-Remote-Groups {header.Remote-Groups}
				request_header X-Remote-Name {header.Remote-Name}
				request_header X-Remote-Email {header.Remote-Email}
					forward_auth workspace-provisioner:8120 {
						uri /api/workspaces/{re.workspace_shell.1}/shell/auth
					copy_headers X-Workspace-Ttyd-Port X-Workspace-Ttyd-Base-Path X-Workspace-Health
					header_up X-Remote-User {header.X-Remote-User}
						header_up X-Remote-Groups {header.X-Remote-Groups}
						header_up X-Remote-Name {header.X-Remote-Name}
						header_up X-Remote-Email {header.X-Remote-Email}
						header_up X-Trusted-Proxy-Secret {$WORKSPACE_PROXY_AUTH_SECRET}
					}
				header X-Workspace-Health {header.X-Workspace-Health}
				reverse_proxy {$WORKSPACE_RUNTIME_PUBLIC_HOST}:{header.X-Workspace-Ttyd-Port}
			}
		}
		@workspace_notebook_root path_regexp workspace_notebook_root ^/w/([^/]+)/notebook$
		handle @workspace_notebook_root {
			redir /w/{re.workspace_notebook_root.1}/notebook/ 308
		}
		@workspace_notebook path_regexp workspace_notebook ^/w/([^/]+)/notebook(/.*)?$
		handle @workspace_notebook {
			route {
				import keycloak_auth workspaces_notebook
				request_header X-Remote-User {header.Remote-User}
				request_header X-Remote-Groups {header.Remote-Groups}
				request_header X-Remote-Name {header.Remote-Name}
				request_header X-Remote-Email {header.Remote-Email}
				forward_auth workspace-provisioner:8120 {
					uri /api/workspaces/{re.workspace_notebook.1}/notebook/auth
					copy_headers X-Workspace-Notebook-Port X-Workspace-Notebook-Base-Path
					header_up X-Remote-User {header.X-Remote-User}
					header_up X-Remote-Groups {header.X-Remote-Groups}
					header_up X-Remote-Name {header.X-Remote-Name}
					header_up X-Remote-Email {header.X-Remote-Email}
					header_up X-Trusted-Proxy-Secret {$WORKSPACE_PROXY_AUTH_SECRET}
				}
				reverse_proxy {$WORKSPACE_RUNTIME_PUBLIC_HOST}:{header.X-Workspace-Notebook-Port}
			}
		}
		@workspace_public_api path /api/oidc/discovery
		handle @workspace_public_api {
			reverse_proxy workspace-provisioner:8120 {
				transport http {
					response_header_timeout 5m
				}
				header_up -Remote-User
				header_up -Remote-Groups
				header_up -Remote-Name
				header_up -Remote-Email
				header_up -X-Trusted-Proxy-Secret
			}
		}
		@workspace_api_bearer {
			path /api/*
			header Authorization *
		}
		handle @workspace_api_bearer {
			reverse_proxy workspace-provisioner:8120 {
				transport http {
					response_header_timeout 5m
				}
				header_up -Remote-User
				header_up -Remote-Groups
				header_up -Remote-Name
				header_up -Remote-Email
				header_up -X-Trusted-Proxy-Secret
			}
		}
		import keycloak_auth workspaces
		reverse_proxy workspace-provisioner:8120 {
			transport http {
				response_header_timeout 5m
			}
			header_up Remote-User {header.Remote-User}
			header_up Remote-Groups {header.Remote-Groups}
			header_up Remote-Name {header.Remote-Name}
			header_up Remote-Email {header.Remote-Email}
			header_up X-Trusted-Proxy-Secret {$WORKSPACE_PROXY_AUTH_SECRET}
		}
	}
}

# Mail hostname: keep an HTTPS virtual host so Caddy obtains/renews TLS certs
# consumed by the SMTP/IMAP stack.
mail.{$DOMAIN} {
	import access_observability
	respond "Mail endpoint is not served over HTTPS" 404
}

# JupyterHub - Uses RemoteUserAuthenticator with forward_auth
jupyterhub.{$DOMAIN} {
	import access_observability
	route {
		# Keep the browser-facing single-user server traffic on JupyterHub's own
		# session model so websocket and API requests are not re-authenticated by
		# the edge on every request.
		@jupyter_session path /hub/api/* /user/*
		handle @jupyter_session {
			reverse_proxy jupyterhub:8000
		}

		handle {
			import keycloak_auth jupyterhub
			reverse_proxy jupyterhub:8000 {
				header_up Remote-User {header.Remote-User}
				header_up Remote-Groups {header.Remote-Groups}
				header_up Remote-Name {header.Remote-Name}
				header_up Remote-Email {header.Remote-Email}
			}
		}
	}
}

# Home Assistant - Uses Keycloak edge auth
# Webhooks must bypass auth
homeassistant.{$DOMAIN}, home.{$DOMAIN} {
	import access_observability
	# Webhook paths bypass forward_auth
	@webhooks path /api/webhook/*
	handle @webhooks {
		reverse_proxy homeassistant:8123
	}

	# All other paths use forward_auth
	route {
		import keycloak_auth homeassistant
		reverse_proxy homeassistant:8123 {
			header_up -X-Forwarded-For
			header_up Remote-User {header.Remote-User}
			header_up Remote-Groups {header.Remote-Groups}
			header_up Remote-Name {header.Remote-Name}
			header_up Remote-Email {header.Remote-Email}
		}
	}
}

# Home Assistant API (for programmatic access with long-lived access tokens)
# API clients authenticate using HA long-lived access tokens in Authorization header
api.homeassistant.{$DOMAIN}, api.home.{$DOMAIN} {
	import access_observability
	# API endpoints (bypass forward_auth, rely on HA's token auth)
	@api path /api/*
	handle @api {
		reverse_proxy homeassistant:8123 {
			header_up -X-Forwarded-For
		}
	}

	# Webhooks (no auth required - webhook IDs are secret)
	@webhooks path /api/webhook/*
	handle @webhooks {
		reverse_proxy homeassistant:8123
	}

	# WebSocket API (requires token in connection URL)
	@websocket path /api/websocket
	handle @websocket {
		reverse_proxy homeassistant:8123 {
			header_up -X-Forwarded-For
		}
	}

	# Return 404 for non-API paths
	respond 404
}

