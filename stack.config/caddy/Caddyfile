			header_up X-WEBAUTH-NAME {header.Remote-Name}
		}
	}
}

# Vaultwarden (OIDC)
vaultwarden.{$DOMAIN}, pass.{$DOMAIN} {
	import access_observability
	@vw_sso_login path /sso-login /sso-login/
	handle @vw_sso_login {
		import keycloak_auth vaultwarden
		# The generic web-vault SSO button asks for an email/domain before it can
		# choose an organization. This stack is single-tenant, so preselect the
		# internal organization and carry the trusted Keycloak email when the web
		# vault supports prefilling it.
		redir * "/#/sso?identifier={$VAULTWARDEN_ORG_ID}&email={http.request.header.Remote-Email}" 302
	}

	@vw_auto_enroll path_regexp vw_auto_enroll ^/api/organizations/[^/]+/auto-enroll-status$
	handle @vw_auto_enroll {
		header Content-Type application/json
		# Vaultwarden 2026.x expects both id and identifier to be the resolved org UUID.
		# Returning the old autoEnrollEnabled payload shape causes set-password to submit
		# the domain identifier instead, which the backend cannot resolve as an org UUID.
		respond "{\"id\":\"{$VAULTWARDEN_ORG_ID}\",\"identifier\":\"{$VAULTWARDEN_ORG_ID}\",\"resetPasswordEnabled\":false}" 200
	}

	@vw_master_password_policy path_regexp vw_master_password_policy ^/api/organizations/[^/]+/policies/master-password$
	handle @vw_master_password_policy {
		header Content-Type application/json
		# Fresh SSO users are not yet organization members when Vaultwarden
		# performs its onboarding policy lookup. Returning an empty policy
		# keeps the flow on the set-initial-password path instead of bouncing
		# back to the login screen on a 401.
		respond "{\"Object\":\"masterPasswordPolicy\"}" 200
	}

	@vw_org_undefined path_regexp vw_org_undefined ^/api/organizations/undefined/(.*)$
	handle @vw_org_undefined {
		rewrite * /api/organizations/{$VAULTWARDEN_ORG_ID}/{re.vw_org_undefined.1}
		reverse_proxy vaultwarden:80
	}

	@vw_org_empty path_regexp vw_org_empty ^/api/organizations//(.*)$
	handle @vw_org_empty {
		rewrite * /api/organizations/{$VAULTWARDEN_ORG_ID}/{re.vw_org_empty.1}
		reverse_proxy vaultwarden:80
	}

	handle {
		reverse_proxy vaultwarden:80
	}
}

