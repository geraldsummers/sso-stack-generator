# MatrixRTC backend for Element Call. Authentication is handled by Matrix OpenID
# tokens at the MatrixRTC authorization service; do not put edge SSO in this path.
matrix-rtc.{$DOMAIN} {
	import access_observability

	@matrix_rtc_jwt path /livekit/jwt /livekit/jwt/*
	handle @matrix_rtc_jwt {
		uri strip_prefix /livekit/jwt
		reverse_proxy matrix-rtc-auth:8080 {
			header_up Host {host}
			header_up X-Forwarded-Server {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	@matrix_rtc_sfu path /livekit/sfu /livekit/sfu/*
	handle @matrix_rtc_sfu {
		uri strip_prefix /livekit/sfu
		reverse_proxy livekit:7880 {
			header_up Host {host}
			header_up X-Forwarded-Server {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	respond 404
}

# Mastodon (web)
# With OMNIAUTH_ONLY=true, Mastodon auto-redirects unauthenticated users to OIDC
mastodon.{$DOMAIN}, social.{$DOMAIN} {
	import access_observability
	reverse_proxy mastodon-web:3000 {
		# Prevent timeout on slow initial requests
		transport http {
			dial_timeout 10s
			response_header_timeout 30s
		}

		# Ensure proper headers for Rails HostAuthorization
		header_up X-Real-IP {remote_host}
	}
}

