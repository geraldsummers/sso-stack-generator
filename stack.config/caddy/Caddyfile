# BookStack API (internal token only - for data-fetcher and search services)
api.bookstack.{$DOMAIN} {
	import access_observability

	@bookstack_api_authorized {
		path /api /api/*
		header X-Internal-Token {$BOOKSTACK_INTERNAL_API_TOKEN}
	}
	handle @bookstack_api_authorized {
		request_header -X-Internal-Token
		reverse_proxy bookstack:80
	}

	@bookstack_api path /api /api/*
	handle @bookstack_api {
		respond "Access denied: internal token required" 403
	}

	respond 404
}

# Seafile - Uses remote user authentication with forward_auth
seafile.{$DOMAIN}, files.{$DOMAIN} {
	import access_observability
	route {
		# Seafile's file server URLs embed access tokens, and OnlyOffice callbacks are
		# authenticated by the shared JWT. These server-to-server endpoints must not
		# bounce through the browser SSO flow.
		@seafile_integration path /seafhttp/* /onlyoffice/editor-callback /onlyoffice/editor-callback/*
		handle @seafile_integration {
			reverse_proxy seafile:80
		}

		import keycloak_auth seafile
		reverse_proxy seafile:80
	}
}

# Seafile API (for API token authentication - bypasses forward_auth)
# API clients authenticate using Seafile API tokens in Authorization header
