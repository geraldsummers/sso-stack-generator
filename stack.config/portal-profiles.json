      "services": ["sogo", "matrix", "planka", "donetick", "bookstack", "seafile", "erpnext", "chatgpt-connector"]
    },
    {
      "id": "client",
      "name": "Client / Customer Portal",
      "defaultView": "client-home",
      "purpose": "A scoped customer portal for requests, deliverables, files, approvals, meetings, and invoices.",
      "widgets": ["client_requests", "deliverables", "client_files", "client_docs", "meeting_history", "invoices", "support_links"],
      "services": ["seafile", "bookstack", "planka", "erpnext", "sogo", "matrix"]
