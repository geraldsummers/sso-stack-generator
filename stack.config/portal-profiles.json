      "widgets": ["revenue", "cash_runway", "receivables", "pipeline", "delivery_health", "client_health", "executive_brief"],
      "services": ["erpnext", "planka", "sogo", "bookstack", "seafile", "search", "chatgpt-connector", "grafana"]
