#!/usr/bin/env bash
set -euo pipefail

env_file="${STACK_AGENT_ENV_FILE:-$HOME/.config/webservices/agent.env}"
if [ ! -f "$env_file" ]; then
    echo "Workspace agent environment not found: $env_file" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "$env_file"

document_id="${1:-}"
collection="${2:-}"

if [ -z "$document_id" ]; then
    echo "Usage: stack-doc-get <document-id> [collection]" >&2
    exit 1
fi

encoded_document_id="$(printf '%s' "$document_id" | jq -sRr @uri)"
url="${STACK_KNOWLEDGE_DOCUMENT_URL_PREFIX}${encoded_document_id}"
if [ -n "$collection" ]; then
    url="${url}?collection=$(printf '%s' "$collection" | jq -sRr @uri)"
fi

exec curl -fsS \
    -H "Authorization: Bearer ${STACK_AGENT_TOKEN}" \
    "$url"
