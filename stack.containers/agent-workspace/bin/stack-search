#!/usr/bin/env bash
set -euo pipefail

env_file="${STACK_AGENT_ENV_FILE:-$HOME/.config/webservices/agent.env}"
if [ ! -f "$env_file" ]; then
    echo "Workspace agent environment not found: $env_file" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "$env_file"

query=""
mode="${STACK_KNOWLEDGE_MODE:-hybrid}"
limit="${STACK_KNOWLEDGE_LIMIT:-10}"
audience="${STACK_KNOWLEDGE_AUDIENCE:-agent}"
collections=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --mode)
            mode="$2"
            shift 2
            ;;
        --limit)
            limit="$2"
            shift 2
            ;;
        --audience)
            audience="$2"
            shift 2
            ;;
        --collection|--collections)
            collections+=("$2")
            shift 2
            ;;
        --help|-h)
            echo "Usage: stack-search [--mode MODE] [--limit N] [--audience AUDIENCE] [--collection NAME]... <query>" >&2
            exit 0
            ;;
        *)
            if [ -z "$query" ]; then
                query="$1"
            else
                query="$query $1"
            fi
            shift
            ;;
    esac
done

if [ -z "$query" ]; then
    echo "stack-search requires a query" >&2
    exit 1
fi

if [ "${#collections[@]}" -eq 0 ]; then
    collections=("*")
fi

payload="$({
    printf '%s\0' "${collections[@]}" | jq -Rs --arg query "$query" --arg mode "$mode" --argjson limit "$limit" --arg audience "$audience" '
        {
          query: $query,
          mode: $mode,
          limit: $limit,
          audience: $audience,
          collections: (split("\u0000") | map(select(length > 0)))
        }
    '
})"

exec curl -fsS \
    -H "Authorization: Bearer ${STACK_AGENT_TOKEN}" \
    -H 'Content-Type: application/json' \
    -X POST \
    --data "$payload" \
    "${STACK_KNOWLEDGE_SEARCH_URL}"
