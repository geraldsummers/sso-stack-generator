#!/usr/bin/env bash
set -euo pipefail

env_file="${STACK_AGENT_ENV_FILE:-$HOME/.config/webservices/agent.env}"

if [ ! -f "$env_file" ]; then
    echo "Workspace agent environment not found: $env_file" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "$env_file"

case "${1:-status}" in
    status)
        printf 'workspace_id=%s\n' "${STACK_WORKSPACE_ID:-<unset>}"
        printf 'controller_url=%s\n' "${STACK_WORKSPACES_URL:-<unset>}"
        printf 'token_present=%s\n' "$(if [ -n "${STACK_AGENT_TOKEN:-}" ]; then echo yes; else echo no; fi)"
        printf 'token_expires_at=%s\n' "${STACK_AGENT_TOKEN_EXPIRES_AT:-<unset>}"
        printf 'search_url=%s\n' "${STACK_KNOWLEDGE_SEARCH_URL:-<unset>}"
        printf 'document_url_prefix=%s\n' "${STACK_KNOWLEDGE_DOCUMENT_URL_PREFIX:-<unset>}"
        ;;
    export)
        cat "$env_file"
        ;;
    token)
        printf '%s\n' "${STACK_AGENT_TOKEN:-}"
        ;;
    *)
        echo "Usage: stack-auth [status|export|token]" >&2
        exit 1
        ;;
esac
