#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<USAGE
Usage: agent-aider-run [--cwd DIR] [--task-file FILE | --task TEXT] [--output-file FILE] [--skip-git-repo-check] [--file FILE]... [--read FILE]...
USAGE
}

cwd="$PWD"
task_file=""
task_text=""
output_file=""
skip_git_repo_check=0
editable_files=()
read_only_files=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --cwd)
            cwd="$2"
            shift 2
            ;;
        --task-file)
            task_file="$2"
            shift 2
            ;;
        --task)
            task_text="$2"
            shift 2
            ;;
        --output-file)
            output_file="$2"
            shift 2
            ;;
        --skip-git-repo-check)
            skip_git_repo_check=1
            shift
            ;;
        --file)
            editable_files+=("$2")
            shift 2
            ;;
        --read)
            read_only_files+=("$2")
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

if [ -n "$task_file" ] && [ -n "$task_text" ]; then
    echo "Specify either --task-file or --task, not both" >&2
    exit 1
fi
if [ -z "$task_file" ] && [ -z "$task_text" ]; then
    echo "A task is required" >&2
    exit 1
fi
if [ -n "$task_file" ] && [ ! -f "$task_file" ]; then
    echo "Task file not found: $task_file" >&2
    exit 1
fi
if [ -z "${AIDER_MODEL:-}" ]; then
    echo "AIDER_MODEL is required" >&2
    exit 1
fi
if [ -z "${AIDER_OLLAMA_API_BASE:-}" ]; then
    echo "AIDER_OLLAMA_API_BASE is required" >&2
    exit 1
fi

mkdir -p "$HOME/.aider" "$HOME/state/session-journal" "$HOME/outputs/aider"
run_stamp="$(date -u +%Y%m%dT%H%M%SZ)"
log_file="$HOME/state/session-journal/aider-${run_stamp}.log"
if [ -z "$output_file" ]; then
    output_file="$HOME/outputs/aider/last-message-${run_stamp}.txt"
fi

task_source="$task_file"
temp_task_file=""
if [ -z "$task_source" ]; then
    temp_task_file="$(mktemp)"
    printf '%s\n' "$task_text" > "$temp_task_file"
    task_source="$temp_task_file"
fi

cleanup() {
    [ -n "$temp_task_file" ] && rm -f "$temp_task_file"
}
trap cleanup EXIT

cmd=(
    aider
    --model "ollama_chat/${AIDER_MODEL}"
    --edit-format "${AIDER_EDIT_FORMAT:-whole}"
    --yes-always
    --no-auto-commits
    --no-dirty-commits
    --no-show-model-warnings
    --no-check-model-accepts-settings
    --no-suggest-shell-commands
    --no-pretty
    --no-stream
    --map-refresh files
    --set-env "OLLAMA_API_BASE=${AIDER_OLLAMA_API_BASE}"
    --message-file "$task_source"
    --exit
)

if [ -n "${AIDER_TIMEOUT:-}" ]; then
    cmd+=(--timeout "$AIDER_TIMEOUT")
fi
if [ -n "${AIDER_MAP_TOKENS:-}" ]; then
    cmd+=(--map-tokens "$AIDER_MAP_TOKENS")
fi
if [ "$skip_git_repo_check" -eq 1 ] || [ "${AIDER_SKIP_GIT_REPO_CHECK:-0}" = "1" ]; then
    cmd+=(--skip-sanity-check-repo)
fi

for file_path in "${editable_files[@]}"; do
    cmd+=("$file_path")
done
for file_path in "${read_only_files[@]}"; do
    cmd+=(--read "$file_path")
done

{
    printf '[agent-aider-run] cwd=%s\n' "$cwd"
    printf '[agent-aider-run] output_file=%s\n' "$output_file"
    printf '[agent-aider-run] model=%s\n' "$AIDER_MODEL"
    printf '[agent-aider-run] api_base=%s\n' "$AIDER_OLLAMA_API_BASE"
    printf '[agent-aider-run] command='
    printf '%q ' "${cmd[@]}"
    printf '\n'
} | tee "$log_file"

(
    cd "$cwd"
    set +e
    "${cmd[@]}" \
        > >(tee "$output_file" | tee -a "$log_file") \
        2> >(tee -a "$log_file" >&2)
    exit_code=$?
    set -e
    printf '[agent-aider-run] transcript=%s\n' "$output_file" | tee -a "$log_file"
    exit "$exit_code"
)
