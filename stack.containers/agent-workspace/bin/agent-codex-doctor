#!/usr/bin/env bash
set -euo pipefail

codex_env_file="${CODEX_ENV_FILE:-$HOME/.config/webservices/codex.env}"
if [ -f "$codex_env_file" ]; then
    # shellcheck disable=SC1090
    . "$codex_env_file"
fi
if [ -n "${CODEX_API_KEY:-}" ] && [ -z "${OPENAI_API_KEY:-}" ]; then
    export OPENAI_API_KEY="$CODEX_API_KEY"
fi

printf 'codex=%s\n' "$(command -v codex)"
printf 'codex_version=%s\n' "$(codex --version)"
printf 'codex_model=%s\n' "${CODEX_MODEL:-<unset>}"
printf 'codex_base_url=%s\n' "${CODEX_BASE_URL:-<unset>}"
printf 'codex_api_key=%s\n' "$(if [ -n "${CODEX_API_KEY:-}" ]; then echo set; else echo unset; fi)"
printf 'openai_api_key=%s\n' "$(if [ -n "${OPENAI_API_KEY:-}" ]; then echo set; else echo unset; fi)"
printf 'codex_env_file=%s\n' "$(if [ -f "$codex_env_file" ]; then echo present; else echo absent; fi)"
printf 'docker=%s\n' "$(docker --version 2>/dev/null || echo unavailable)"
printf 'docker_compose=%s\n' "$(docker compose version 2>/dev/null || echo unavailable)"
printf 'stack_agent_env=%s\n' "$(if [ -f "${STACK_AGENT_ENV_FILE:-$HOME/.config/webservices/agent.env}" ]; then echo present; else echo absent; fi)"
printf 'stack_search_helper=%s\n' "$(command -v stack-search 2>/dev/null || echo unavailable)"
