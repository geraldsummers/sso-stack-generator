#!/usr/bin/env bash
set -euo pipefail

profiles_dir="${AGENT_TOOLCHAINS_DIR:-/opt/agent-toolchains}/profiles"
for profile_dir in "$profiles_dir"/*; do
    [ -d "$profile_dir" ] || continue
    profile_name="$(basename "$profile_dir")"
    tier="unknown"
    summary=""
    if [ -f "$profile_dir/profile.env" ]; then
        # shellcheck disable=SC1090
        source "$profile_dir/profile.env"
        tier="${TIER:-unknown}"
        summary="${SUMMARY:-}"
    fi
    printf '%s\t%s\t%s\n' "$profile_name" "$tier" "$summary"
done | sort
