#!/usr/bin/env python3
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path


def iso_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_profile_env(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    for raw_line in path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key.strip()] = value.strip().strip("'").strip('"')
    return values


def load_catalog(profiles_dir: Path) -> list[dict[str, str]]:
    catalog: list[dict[str, str]] = []
    for profile_dir in sorted(path for path in profiles_dir.iterdir() if path.is_dir()):
        env_file = profile_dir / "profile.env"
        meta = parse_profile_env(env_file) if env_file.exists() else {}
        catalog.append(
            {
                "name": profile_dir.name,
                "tier": meta.get("TIER", "unknown"),
                "summary": meta.get("SUMMARY", ""),
            }
        )
    return catalog


def load_manifest(manifest_path: Path) -> dict:
    if not manifest_path.exists():
        return {"schema": 1, "updated_at": "", "profiles": []}
    return json.loads(manifest_path.read_text())


def write_manifest(manifest_path: Path, manifest: dict) -> None:
    manifest_path.parent.mkdir(parents=True, exist_ok=True)
    manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")


def append_history(history_path: Path, event: dict) -> None:
    history_path.parent.mkdir(parents=True, exist_ok=True)
    with history_path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(event, sort_keys=True) + "\n")


def seed_manifest(catalog: list[dict[str, str]], manifest: dict, now: str) -> dict:
    existing = {entry["name"]: entry for entry in manifest.get("profiles", [])}
    profiles = []
    for entry in catalog:
        previous = existing.get(entry["name"], {})
        state = previous.get("status")
        source = previous.get("source")
        last_applied_at = previous.get("last_applied_at")
        if entry["tier"] == "base":
            state = state if state in {"present", "installed"} else "present"
            source = source or "base-image"
            last_applied_at = last_applied_at or now
        else:
            state = state or "available"
            source = source or "catalog"
        profiles.append(
            {
                "name": entry["name"],
                "tier": entry["tier"],
                "summary": entry["summary"],
                "status": state,
                "source": source,
                "last_applied_at": last_applied_at,
            }
        )
    return {"schema": 1, "updated_at": now, "profiles": profiles}


def main() -> int:
    if len(sys.argv) < 2:
        print("Usage: agent-sync-profile-state <seed|record-install> [profile]", file=sys.stderr)
        return 1

    command = sys.argv[1]
    profiles_dir = Path(os.environ.get("AGENT_TOOLCHAINS_DIR", "/opt/agent-toolchains")) / "profiles"
    state_dir = Path(os.environ.get("AGENT_PROFILE_STATE_DIR", Path.home() / ".local/share/agent/profile-state"))
    manifest_path = state_dir / "manifest.json"
    history_path = state_dir / "install-history.jsonl"
    now = iso_now()

    manifest = seed_manifest(load_catalog(profiles_dir), load_manifest(manifest_path), now)

    if command == "seed":
        write_manifest(manifest_path, manifest)
        return 0

    if command == "record-install":
        if len(sys.argv) < 3:
            print("record-install requires a profile name", file=sys.stderr)
            return 1
        profile_name = sys.argv[2]
        matching = next((entry for entry in manifest["profiles"] if entry["name"] == profile_name), None)
        if matching is None:
            print(f"Unknown profile: {profile_name}", file=sys.stderr)
            return 1
        matching["status"] = "installed"
        matching["source"] = "workspace-install"
        matching["last_applied_at"] = now
        manifest["updated_at"] = now
        append_history(
            history_path,
            {
                "event": "profile_installed",
                "profile": profile_name,
                "recorded_at": now,
            },
        )
        write_manifest(manifest_path, manifest)
        return 0

    print(f"Unknown command: {command}", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
