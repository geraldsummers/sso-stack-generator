# Ignore local volumes directory (containers data, models, databases, etc.)
# Anchored to the repository root to avoid matching similarly named paths elsewhere.

# Secrets and sensitive data

.env
.env.server
.env.local
volumes/secrets/
stack.config/model-context-server/shadow-accounts/*.pwd
*.key
stackops_ed25519
.gradle/
# Generated configuration files (from templates)
# Now generated during build process in dist/
# (No longer needed in project - all configs in build output)
dist/
__pycache__/
*.pyc
# Runtime data
volumes/
!volumes/.gitkeep

# Docker
.docker/
.gradle/*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

