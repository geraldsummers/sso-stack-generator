*.tmp
*.bak1
*.backup
tmp/
.tmp/

#SATURN stuff
build/
downloads/
isofiles/
id_ed*
/volumes/
*.iso
# SSH keys (NEVER COMMIT)
ssh-keystore/
id_ed25519*
*.pem
!*.pem.example

# No encrypted secrets - keep local secrets in ~/.config/stack
venv/

